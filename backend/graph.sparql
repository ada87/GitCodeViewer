PREFIX ex: <https://example.org/schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?s ?p ?o WHERE {
  ?s ex:id 1 ;
     ?p ?o .
  FILTER(?o != "skip_1")
} LIMIT 10


{% set health_color = {
  "healthy": "#166534",
  "review": "#92400e",
  "pending": "#6b7280"
} %}
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>{{ release.title }}</title>
    <style>
      body { font: 15px/1.6 "Segoe UI", sans-serif; color: #1f2937; }
      .hero { padding: 24px; background: linear-gradient(135deg, #eef3fb, #fff4db); }
      .section { padding: 20px 24px; }
      .badge { display: inline-block; padding: 3px 9px; border-radius: 999px; font-size: 12px; }
      .repo { padding: 14px 0; border-bottom: 1px solid #e5e7eb; }
      table { width: 100%; border-collapse: collapse; }
      th, td { text-align: left; padding: 8px 0; border-bottom: 1px solid #e5e7eb; }
    </style>
  </head>
  <body>
    <header class="hero">
      <h1>{{ release.title }}</h1>
      <p>{{ release.summary }}</p>
      <p>
        <strong>Version:</strong> {{ release.version }}
        <strong>Target:</strong> {{ release.target_platform }}
        <strong>Date:</strong> {{ release.date_label }}
      </p>
    </header>

    <section class="section">
      <h2>Highlights</h2>
      <ul>
        {% for note in release.highlights %}
        <li>{{ note }}</li>
        {% endfor %}
      </ul>
    </section>

    <section class="section">
      <h2>Release metadata</h2>
      <table>
        <tr><th>Build channel</th><td>{{ release.channel }}</td></tr>
        <tr><th>Workspace count</th><td>{{ release.workspaces|length }}</td></tr>
        <tr><th>Primary reviewer</th><td>{{ release.reviewer }}</td></tr>
        <tr><th>Notes path</th><td>{{ release.notes_path }}</td></tr>
      </table>
    </section>

    <section class="section">
      <h2>Workspace health</h2>
      {% for repo in release.workspaces %}
      <div class="repo">
        <h3>{{ repo.name }}</h3>
        <p>{{ repo.owner }} / {{ repo.branch }}</p>
        <span class="badge" style="background: {{ repo.status_bg }}; color: {{ health_color[repo.status] }};">
          {{ repo.status|capitalize }}
        </span>
        <p>{{ repo.note }}</p>
      </div>
      {% endfor %}
    </section>

    <section class="section">
      <h2>Next actions</h2>
      <ol>
        {% for action in release.next_actions %}
        <li>
          {{ action.label }}
          {% if action.owner %}<small>Owner: {{ action.owner }}</small>{% endif %}
        </li>
        {% endfor %}
      </ol>
    </section>

    <footer class="section">
      <p>This template is used by the release mailer to render a readable summary for internal review.</p>
    </footer>
  </body>
</html>